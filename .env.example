APP_NAME="FruGo"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8080

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Database ---
# Docker (local): use the service name as host
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=product_manager
DB_USERNAME=pmuser
DB_PASSWORD=pmpassword

# --- Session / Cache ---
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

# --- Mail ---
# Local (Docker): MailHog on port 1025, web UI on http://localhost:8025
MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@frugo.com"
MAIL_FROM_NAME="FruGo"

VITE_APP_NAME="${APP_NAME}"

# ---------------------------------------------------------------------------
# Vercel deployment — set these as environment variables in the Vercel dashboard
# ---------------------------------------------------------------------------
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://your-project.vercel.app
# APP_KEY=base64:...          (generate: php artisan key:generate --show)
#
# DB_HOST=<PlanetScale / Railway host>
# DB_PORT=3306
# DB_DATABASE=<your_db>
# DB_USERNAME=<user>
# DB_PASSWORD=<password>
#
# SESSION_DRIVER=cookie         (serverless: no writable filesystem for file sessions)
# CACHE_STORE=array             (serverless: no persistent cache needed)
# LOG_CHANNEL=stderr            (Vercel captures stderr as function logs)
#
# MAIL_MAILER=smtp              (use Mailgun, Resend, or similar transactional service)
# MAIL_HOST=smtp.mailgun.org
# MAIL_PORT=587
# MAIL_USERNAME=<mailgun_user>
# MAIL_PASSWORD=<mailgun_password>
# MAIL_FROM_ADDRESS="noreply@yourdomain.com"
